# Copie para .env e preencha para testar localmente (NAO commite o .env).
# Ex.: no PowerShell, carregue antes de rodar, ou defina como variaveis de ambiente.

# URL da sua instancia Jira Cloud (sem barra no final)
JIRA_BASE_URL=https://suaempresa.atlassian.net

# Email da conta Atlassian dona do API token
JIRA_EMAIL=voce@suaempresa.com.br

# API token gerado em https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=seu_token_aqui

# Webhook do canal do Discord (Config. do canal > Integracoes > Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# OPCIONAL: restringir a projetos especificos (chaves separadas por virgula).
# Deixe em branco para cobrir TODOS os projetos.
JIRA_PROJECTS=

# OPCIONAL: filtro JQL extra aplicado a todas as consultas.
# Ex.: labels != interno
JIRA_EXTRA_JQL=

# OPCIONAL: tipo(s) de issue que representam "erro/bug" (separados por virgula).
# Padrao: Erro. Use "Bug" ou outros conforme seu Jira.
JIRA_BUG_TYPES=Erro
